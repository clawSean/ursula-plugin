  "type": "module",
  "description": "OpenClaw /ursula command that releases recent assistant replies as TTS voice notes",
  "license": "MIT",
  "author": "clawSean",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clawSean/ursula-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/clawSean/ursula-plugin/issues"
  },
  "homepage": "https://github.com/clawSean/ursula-plugin#readme",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "tts",
    "voice-note",
    "slash-command",
